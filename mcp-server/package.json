{
  "name": "@matric/memory-mcp",
  "version": "2026.1.11",
  "description": "MCP server for Matric Memory API",
  "main": "index.js",
  "type": "module",
  "bin": {
    "matric-memory-mcp": "./index.js"
  },
  "scripts": {
    "start": "node index.js",
    "start:http": "MCP_TRANSPORT=http node index.js",
    "test": "node test-mcp-connectivity.js",
    "test:local": "MATRIC_MEMORY_URL=http://localhost:3000 node test-mcp-connectivity.js",
    "test:oauth": "echo 'Usage: MCP_CLIENT_ID=xxx MCP_CLIENT_SECRET=yyy npm run test'"
  },
  "license": "SEE LICENSE IN ../LICENSE",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^4.18.2",
    "cors": "^2.8.5"
  }
}
