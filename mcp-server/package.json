{
  "name": "@fortemi/mcp",
  "version": "2026.7.0",
  "description": "MCP server for Fortémi API",
  "main": "index.js",
  "type": "module",
  "bin": {
    "fortemi-mcp": "./index.js"
  },
  "scripts": {
    "start": "node index.js",
    "start:http": "MCP_TRANSPORT=http node index.js",
    "test": "node --test tests/*.test.js",
    "test:schema": "node --test tests/schema-validation.test.js",
    "validate:schemas": "node validate-schemas.cjs",
    "test:annotations": "node --test tests/annotations.test.js",
    "test:errors": "node --test tests/error-responses.test.js",
    "test:connectivity": "node test-mcp-connectivity.js",
    "test:local": "FORTEMI_URL=http://localhost:3000 node test-mcp-connectivity.js",
    "test:oauth": "echo 'Usage: MCP_CLIENT_ID=xxx MCP_CLIENT_SECRET=yyy npm run test'"
  },
  "license": "BUSL-1.1",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^4.18.2",
    "cors": "^2.8.5"
  },
  "overrides": {
    "path-to-regexp@<0.1.13": "0.1.13",
    "router": {
      "path-to-regexp": "8.4.0"
    },
    "hono": "^4.12.26",
    "@hono/node-server": "^1.19.13",
    "fast-uri": "^3.1.2",
    "ip-address": "^10.1.1",
    "qs": "^6.15.2"
  }
}
