{
  "repository": "Fortemi/fortemi",
  "reader_approle": "ci-fortemi",
  "bootstrap_tracker_secrets": [
    "BAO_CI_ROLE_ID",
    "BAO_CI_SECRET_ID"
  ],
  "tracker_variables": [
    "DEPLOY_HOST",
    "DEPLOY_PORT",
    "DEPLOY_USER",
    "DEPLOY_PATH",
    "DEPLOY_PATH_PORTAL",
    "CLOUDFLARE_ZONE_ID"
  ],
  "leaves": [
    {
      "mount": "kv_internal",
      "path": "ci/fortemi/gitea-build-token",
      "field": "token",
      "type": "api-token",
      "service": "ci/fortemi",
      "owner": "itops",
      "tenant": "internal",
      "purpose": "Gitea registry publish, workflow dispatch, and release API token for Fortemi",
      "consumers": "gitea-actions:fortemi:build-builder,ci-builder,build-gliner,build-pyannote,release",
      "reader_approle": "ci-fortemi",
      "sensitivity": "high",
      "rotation": "quarterly",
      "sop": "itops/docs/openbao-ci-migration.md"
    },
    {
      "mount": "kv_internal",
      "path": "ci/fortemi/hf-token",
      "field": "token",
      "type": "api-token",
      "service": "ci/fortemi",
      "owner": "itops",
      "tenant": "internal",
      "purpose": "Hugging Face token for pyannote model-loading validation in CI",
      "consumers": "gitea-actions:fortemi:build-pyannote",
      "reader_approle": "ci-fortemi",
      "sensitivity": "high",
      "rotation": "quarterly",
      "sop": "itops/docs/openbao-ci-migration.md"
    }
  ],
  "shared_leaves": [
    "kv_internal/ci/shared/cloudflare-api:token",
    "kv_internal/ci/shared/docs-deploy:private_key",
    "kv_internal/ci/shared/ghcr-token:token",
    "kv_internal/ci/shared/mutsu-ssh-key:private_key"
  ]
}
