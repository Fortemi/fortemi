      {
        "field": "model",
        "type": "nominal",
        "title": "Model"
      },
      {
        "field": "score",
        "type": "quantitative",
        "title": "Score",
        "format": ".1f"
      },
      {
        "field": "category",
        "type": "nominal",
        "title": "Category"
      }
    ]
  }
