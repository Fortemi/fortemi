{
  "name": "@matric-memory/evals",
  "version": "0.1.0",
  "description": "Model evaluation framework for matric-memory",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "eval": "tsx src/index.ts eval",
    "eval:embeddings": "tsx src/index.ts eval:embeddings",
    "eval:llms": "tsx src/index.ts eval:llms",
    "report": "tsx src/index.ts report",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
  },
  "keywords": [
    "evaluation",
    "llm",
    "embeddings",
    "matric-memory"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "optionalDependencies": {
    "canvas": "^2.11.2",
    "vega": "^5.30.0",
    "vega-lite": "^5.23.0"
  }
}
