# Fortemi release configuration — consumed by the `flow-release` skill.
# Scaffolded 2026-06-29 for operator review. Tailored to Fortemi's actual
# release process (CLAUDE.md "Releasing"): CalVer, cargo workspace, Docker
# bundle published by CI on tag, Gitea release, and OpenBao-backed two-key
# signing. Ordinary commits and release tags use distinct shared authorities.
version: 1

project:
  name: fortemi
  display_name: Fortémi
  repo_url: https://git.integrolabs.net/Fortemi/fortemi
  mirror_url: https://github.com/Fortemi/fortemi
  # Source refs, release entries, and GHCR images are mirrored by CI.

version_policy:
  format: calver           # YYYY.M.PATCH, no leading zeros (see `versioning` rule)
  pattern: "YYYY.M.PATCH"
  tag_prefix: v
  channels:
    stable:
      tag_format: "v{YYYY}.{M}.{PATCH}"
      require_changelog: true
      require_announcement: true
    rc:
      tag_format: "v{YYYY}.{M}.{PATCH}-rc.{N}"
      require_changelog: true
      require_announcement: false

policy:
  no_ai_attribution: true            # CRITICAL — scan commit/tag/announcement
  ci_green_before_done: true         # never finalize on a red CI run
  preserve_pre_release_announcements: false

publication_verify:
  release_assets:
    - "matric-api-x86_64-unknown-linux-gnu"
    - "matric-api-aarch64-apple-darwin"
    - "matric-api-x86_64-apple-darwin"
    - "SHA256SUMS.txt"
    - "sidecar-provenance.intoto.json"
  checksums:
    manifest: "SHA256SUMS.txt"
    must_cover:
      - "matric-api-x86_64-unknown-linux-gnu"
      - "matric-api-aarch64-apple-darwin"
      - "matric-api-x86_64-apple-darwin"

gates:
  # 1) Local deterministic gate (no DB needed). Full test suite runs in CI (ci-green).
  - name: local-build-test
    hard_stop: true
    steps:
      - id: fmt
        run: cargo fmt --all -- --check
      - id: clippy
        run: cargo clippy --all-targets --all-features -- -D warnings
      - id: docs-contract
        run: DOCS_CONTRACT_MODE=blocking npm run docs:contract -- --profile=hosted_strict
      - id: deny
        run: cargo deny check advisories bans licenses sources
      - id: lib-tests
        run: cargo test --lib --workspace
        # Integration/DB tests run in CI (ci-green gate); they require a test DB.

  # 2) Documentation sync (code is source of truth).
  - name: doc-sync
    hard_stop: true
    invoke_skill: doc-sync
    args:
      direction: code-to-docs
      dry_run_first: true
      guidance: |
        Reconcile docs/content/, CLAUDE.md, AIWG.md, and docs/architecture to the
        current code. Focus: RFC 9457 error contract (#967), telemetry/secret
        redaction (#968/#974), MCP/ADR-100 model, inference providers, and the
        CE/EE split (enterprise tooling now in Fortemi-Enterprise).

  # 3) Version bump (CalVer; no leading zeros). Keep Cargo.toml + mcp-server in lockstep.
  - name: version-bump
    hard_stop: true
    steps:
      - id: cargo-version
        run: "grep -q '^version = \"{version}\"' Cargo.toml || (echo 'Set Cargo.toml workspace version to {version}' && exit 1)"
      - id: mcp-version
        run: "grep -q '\"version\": \"{version}\"' mcp-server/package.json || (echo 'Set mcp-server/package.json version to {version}' && exit 1)"
      - id: mcp-lock-version
        run: "grep -q '\"version\": \"{version}\"' mcp-server/package-lock.json || (echo 'Set mcp-server/package-lock.json version to {version}' && exit 1)"
      - id: no-leading-zeros
        run: "echo '{version}' | grep -Eq '^[0-9]{4}\\.[1-9][0-9]?\\.[0-9]+$' || (echo 'CalVer leading-zero violation' && exit 1)"

  # 4) Changelog + announcement (stable only).
  - name: changelog-and-announcement
    hard_stop: true
    required_for_channels: [stable]
    artifacts:
      - path: CHANGELOG.md
        section_pattern: '## [{version}]'
      - path: docs/releases/v{version}-announcement.md
        must_exist: true

  # 5) Commit + signed tag. TPM-sealed AppRoles fetch each key into tmpfs.
  #    Delivery mode is direct-to-main (.aiwg/aiwg.config), so commit lands on main.
  - name: commit-and-tag
    hard_stop: true
    steps:
      - id: commit
        run: "git add Cargo.toml Cargo.lock mcp-server/package.json mcp-server/package-lock.json CHANGELOG.md docs/releases/v{version}-announcement.md && git -c user.signingkey=62297562B1C7053088F405DB0117DAAA677A5BF2 -c gpg.program=tools/git/gpg-from-openbao.sh commit -S -m 'chore: release {tag}'"
      - id: tag
        run: "tools/release/cut-tag.sh {version} -m '{tag} — release'"
      - id: push
        run: "git push origin main && git push origin {tag}"

  # 6) CI green for the release commit/tag (Gitea Actions).
  - name: ci-green
    hard_stop: true
    tracker: gitea
    owner: Fortemi
    repo: fortemi
    timeout_seconds: 1800
    poll_interval_seconds: 30
    required_workflows: [ci-builder.yaml, test.yml]
    # On tag push, publish-sidecar.yml and GHCR release images also run.

  # 7) Create the Gitea release with CHANGELOG highlights.
  - name: gitea-release
    hard_stop: true
    required_for_channels: [stable]
    actions:
      - update_release_entry: gitea

  # 8) Post-release housekeeping (warn-only).
  - name: post-release
    hard_stop: false
    actions:
      - close_imported_issues_with_thanks: true
