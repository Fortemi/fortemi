{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.fortemi.dev/knowledge-shard/2.0.0/contract.schema.json",
  "title": "Knowledge Shard 2.0 authority descriptor",
  "type": "object",
  "required": [
    "$schema",
    "schemaVersion",
    "contractRevision",
    "status",
    "authority",
    "knowledgeShard",
    "profiles",
    "presenceSemantics",
    "schemaBundle",
    "canonicalCorpus",
    "compatibility",
    "previousAuthority",
    "tracking",
    "claimPolicy"
  ],
  "properties": {
    "$schema": { "const": "https://schemas.fortemi.dev/knowledge-shard/2.0.0/contract.schema.json" },
    "schemaVersion": { "const": 1 },
    "contractRevision": { "const": "20" },
    "status": { "const": "specified-implementation-pending" },
    "authority": { "type": "object" },
    "knowledgeShard": { "type": "object" },
    "profiles": { "type": "object" },
    "presenceSemantics": { "type": "object" },
    "schemaBundle": { "type": "object" },
    "canonicalCorpus": { "type": "object" },
    "compatibility": { "type": "object" },
    "previousAuthority": { "type": "object" },
    "tracking": { "type": "object" },
    "claimPolicy": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
