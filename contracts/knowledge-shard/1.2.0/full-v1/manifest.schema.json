        },
        "skos_schemes.json": {
          "$ref": "#/$defs/sha256"
        },
        "skos_concepts.json": {
          "$ref": "#/$defs/sha256"
        },
        "skos_labels.jsonl": {
          "$ref": "#/$defs/sha256"
        },
        "skos_notes.jsonl": {
          "$ref": "#/$defs/sha256"
        },
        "skos_relations.jsonl": {
          "$ref": "#/$defs/sha256"
        },
        "skos_mapping_relations.jsonl": {
          "$ref": "#/$defs/sha256"
        },
        "skos_scheme_memberships.jsonl": {
          "$ref": "#/$defs/sha256"
        },
        "note_skos_tags.jsonl": {
          "$ref": "#/$defs/sha256"
        },
        "skos_collections.json": {
          "$ref": "#/$defs/sha256"
        },
        "skos_collection_members.jsonl": {
          "$ref": "#/$defs/sha256"
        },
        "graph_sources.json": {
          "$ref": "#/$defs/sha256"
        },
        "graph_edges.jsonl": {
          "$ref": "#/$defs/sha256"
        },
        "communities.json": {
